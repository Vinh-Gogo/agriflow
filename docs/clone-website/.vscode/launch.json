{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Clone Script",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/tools/clone-script.js",
      "args": [
        "https://pathwise.chuongmep.com/"
      ],
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Screenshot Tool",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/tools/screenshot.js",
      "args": [
        "https://pathwise.chuongmep.com/"
      ],
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Extract CSS",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/tools/extract-css.js",
      "args": [
        "https://pathwise.chuongmep.com/"
      ],
      "console": "integratedTerminal"
    },
    {
      "type": "pwa-chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost",
      "url": "http://localhost:5500",
      "webRoot": "${workspaceFolder}/src/html",
      "runtimeArgs": [
        "--disable-web-security",
        "--allow-file-access-from-files"
      ]
    }
  ]
}